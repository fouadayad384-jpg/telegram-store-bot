FROM python:3.12-slim

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    PIP_NO_CACHE_DIR=1

WORKDIR /app

RUN addgroup --system bot && adduser --system --ingroup bot bot

COPY requirements.txt .
RUN pip install --upgrade pip && pip install -r requirements.txt

# GitHub's mobile upload flattened the source tree. Rebuild the Python package
# inside the image so Railway receives the original, deployable layout.
COPY . .
RUN mkdir -p app/routers app/services alembic/versions && \
    cp binance_pay.py bot.py config.py db.py keyboards.py main.py models.py presentation.py security.py app/ && \
    cp user.py app/routers/user.py && \
    cp admin.py app/services/admin.py && \
    cp outbox.py payments.py referrals.py store.py app/services/ && \
    cp env.py script.py.mako alembic/ && \
    cp 0001_initial.py alembic/versions/0001_initial.py && \
    touch app/__init__.py app/routers/__init__.py app/services/__init__.py

# admin.py at the repository root is the service layer; restore the admin
# Telegram router that was lost when duplicate basenames were flattened.
RUN python -c "import base64,gzip,pathlib; pathlib.Path('app/routers/admin.py').write_bytes(gzip.decompress(base64.b64decode('')))"

RUN chown -R bot:bot /app
USER bot

EXPOSE 8000
CMD ["sh", "-c", "exec uvicorn app.main:app --host 0.0.0.0 --port \"${PORT:-8000}\" --proxy-headers --forwarded-allow-ips '*'"]
